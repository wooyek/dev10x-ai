{
  "description": "Safety and quality hooks: block dangerous patterns, enforce JTBD commits, create scratch dirs",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session git-aliases",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session tmpdir",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session guidance",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session migrate-permissions",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start-reload.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook skill tmpdir",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/validate-bash-command.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/validate-edit-write.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session goodbye",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook session persist",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/precompact-context.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/permission-denied.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook skill metrics",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project $CLAUDE_PLUGIN_ROOT dev10x hook ruff-format",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "TaskCreate|TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/task-plan-sync.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
